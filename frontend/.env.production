# GDB Frontend - Docker/Production Environment Variables
# All API calls go through nginx proxy -> gateway-service

VITE_APP_NAME=GDB Banking
VITE_APP_VERSION=1.0.0

# In Docker, all API calls go to the same origin (nginx proxies /api/ to gateway)
VITE_ACCOUNTS_SERVICE_URL=
VITE_TRANSACTIONS_SERVICE_URL=
VITE_USERS_SERVICE_URL=
VITE_AUTH_SERVICE_URL=
VITE_AADHAR_SERVICE_URL=
VITE_COMPANY_CRV_SERVICE_URL=
VITE_NOTIFICATION_SERVICE_URL=
VITE_PAYMENT_GATEWAY_URL=
